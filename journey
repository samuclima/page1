    .site-chat-typing span {
      width: 4px; height: 4px; background: rgba(0,0,0,0.3);
      border-radius: 50%; display: inline-block;
      animation: typing-bounce 1.2s infinite;
    }
    .site-chat-typing span:nth-child(2) { animation-delay: 0.2s; }
    .site-chat-typing span:nth-child(3) { animation-delay: 0.4s; }


    /* ══ PHASE 7 — centered hero title over website ══ */
    .proof-scene {
      position: fixed; top: 0; left: 0;
      width: 100vw; height: 100vh;
      z-index: 6;
      pointer-events: none;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 0 40px;
    }

    /* Dark vignette */
    .proof-vignette {
      position: absolute; inset: 0;
      background: rgba(10,10,10,0.88);
      opacity: 0;
    }

    /* The whole hero block — centred */
    .proof-hero-block {
      position: relative; z-index: 1;
      text-align: center;
      opacity: 0; transform: translateY(32px);
      max-width: 1100px;
      width: 100%;
    }

    /* Eyebrow above headline */
    .proof-hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 13px; font-weight: 600;
      color: rgba(255,255,255,0.45);
      margin-bottom: 22px;
    }
    .proof-hero-eyebrow::before {
      content: "";
      width: 24px; height: 1px;
      background: rgba(255,255,255,0.35);
    }

    /* Giant headline — mirrors .display-h1 */
    .proof-display-h1 {
      font-size: clamp(44px, 7.2vw, 96px);
      font-weight: 800;
      line-height: 0.96;
      letter-spacing: -0.045em;
      color: #fff;
      margin: 0 0 24px;
    }
    .proof-display-h1 .ph-light {
      font-weight: 500;
      color: rgba(255,255,255,0.28);
    }
    /* Inline chip-mockup pill */
    .proof-chip-mockup {
      display: inline-flex; align-items: center;
      vertical-align: middle;
      background: #fff;
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 14px;
      padding: 7px 14px;
      margin: 0 8px;
      font-size: 0.32em;
      font-weight: 700;
      gap: 8px;
      transform: translateY(-12px);
      color: #0a0a0a;
      letter-spacing: normal;
      white-space: nowrap;
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }
    .proof-chip-dot { width: 6px; height: 6px; border-radius: 50%; background: #ff6b2c; flex-shrink: 0; }

    /* Orange aside line */
    .proof-aside {
      display: block;
      font-size: clamp(16px, 2.2vw, 28px);
      font-weight: 700;
      color: #ff6b2c;
      letter-spacing: -0.02em;
      margin-top: 18px;
      line-height: 1;
    }

    /* ══ PHASE 8 — stacking portfolio cards ══ */
    .portfolio-scene {
      position: fixed; top: 0; left: 0;
      width: 100vw; height: 100vh;
      z-index: 20;
      opacity: 0;
      transform: translateY(60px);
      pointer-events: none;
    }

    /* Solid dark bg behind the cards */
    .portfolio-bg {
      position: absolute; inset: 0;
      background: #f4f1ea;
    }

    /* Sticky header block that slides up and stays */
    .portfolio-header {
      position: absolute; top: 0; left: 0; right: 0;
      padding: 110px 0 32px;
      text-align: center;
      transform: translateY(40px);
      opacity: 0;
      z-index: 1;
    }
    .portfolio-header .ph-eyebrow {
      font-size: 13px; font-weight: 700; color: #ff6b2c;
      letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px;
    }
    .portfolio-header h2 {
      font-size: clamp(32px, 4.5vw, 60px);
      font-weight: 800; letter-spacing: -0.045em; line-height: 1;
      color: #0a0a0a; margin: 0 0 12px;
    }
    .portfolio-header h2 em { font-style: normal; color: #ff6b2c; }
    .portfolio-header p {
      font-size: 16px; color: rgba(0,0,0,0.5); margin: 0;
      max-width: 520px; margin: 0 auto; line-height: 1.5;
    }

    /* Stack container — cards pile here */
    .port-stack {
      position: absolute;
      bottom: 0; left: 50%;
      transform: translateX(-50%);
      width: min(960px, 92vw);
      height: calc(100vh - 240px);
      perspective: 1000px;
    }

    /* Individual stacked card */
    .port-stack-card {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 90%;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 24px 60px rgba(0,0,0,0.18), 0 8px 24px rgba(0,0,0,0.1);
      transform: translateY(100%);
      border: 1px solid rgba(0,0,0,0.07);
    }

    /* Two-column grid inside each card */
    .port-card-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      height: 100%;
    }

    /* Left: website screenshot */
    .port-card-img {
      overflow: hidden; position: relative;
    }
    .port-card-img img {
      width: 100%; height: 100%; object-fit: cover; object-position: top;
      display: block;
    }

    /* Right: info panel */
    .port-card-info {
      display: flex; flex-direction: column;
      justify-content: center; padding: 48px 52px;
      background: #fff;
    }
    .port-card-tag {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 11px; font-weight: 700; color: #ff6b2c;
      letter-spacing: 0.07em; text-transform: uppercase;
      margin-bottom: 16px;
    }
    .port-card-tag-dot { width: 5px; height: 5px; border-radius: 50%; background: #ff6b2c; }
    .port-card-name {
      font-size: clamp(28px, 3.5vw, 48px);
      font-weight: 800; letter-spacing: -0.04em;
      line-height: 1.05; color: #0a0a0a; margin: 0 0 14px;
    }
    .port-card-desc {
      font-size: 15px; color: rgba(0,0,0,0.5);
      line-height: 1.6; margin: 0 0 28px;
    }
    .port-card-link {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 14px; font-weight: 700; color: #0a0a0a;
      letter-spacing: -0.01em;
    }
    .port-card-link::after { content: "→"; color: #ff6b2c; }
    .port-card-stat-row {
      display: flex; gap: 20px; margin-top: 28px;
      padding-top: 20px; border-top: 1px solid rgba(0,0,0,0.07);
    }
    .port-card-stat { display: flex; flex-direction: column; gap: 2px; }
    .port-card-stat-num { font-size: 22px; font-weight: 800; letter-spacing: -0.03em; color: #0a0a0a; }
    .port-card-stat-label { font-size: 11px; color: rgba(0,0,0,0.4); font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }

    /* Card colour accents */
    .psc-1 .port-card-info { background: #fff; }
    .psc-2 .port-card-info { background: #f4f1ea; }
    .psc-3 .port-card-info { background: #0a0a0a; }
    .psc-3 .port-card-name,
    .psc-3 .port-card-link,
    .psc-3 .port-card-stat-num { color: #fff; }
    .psc-3 .port-card-desc { color: rgba(255,255,255,0.5); }
