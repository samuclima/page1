    }


    /* ══ GENERATED WEBSITE — editorial design ══ */

    .site-content {
      position: absolute; top: 0; left: 0; width: 100%;
      clip-path: inset(0 0 100% 0); /* starts fully hidden, revealed by GSAP */
      background: #faf7f2;
      font-family: "Cabinet Grotesk", system-ui, sans-serif;
    }

    /* NAV */
    .site-nav {
      height: 52px; background: #faf7f2;
      border-bottom: 1px solid rgba(0,0,0,0.07);
      display: flex; align-items: center;
      padding: 0 32px; justify-content: space-between;
      position: sticky; top: 0; z-index: 10;
    }
    .site-nav-brand { display: flex; align-items: center; gap: 8px; font-size: 16px; font-weight: 900; letter-spacing: -0.04em; color: #1a1008; }
    .site-nav-dot { width: 7px; height: 7px; background: #c8530a; border-radius: 50%; }
    .site-nav-links { display: flex; gap: 22px; font-size: 12px; font-weight: 600; color: rgba(0,0,0,0.45); }
    .site-nav-cta { padding: 7px 16px; background: #1a1008; color: #faf7f2; border-radius: 999px; font-size: 12px; font-weight: 700; }

    /* HERO */
    .site-hero {
      background: #faf7f2;
      min-height: 300px;
      position: relative; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      padding: 44px 32px 36px;
    }

    /* Floating blob shapes — warm earthy palette */
    .blob {
      position: absolute; border-radius: 50%;
      pointer-events: none; opacity: 0.85;
    }
    .blob-1 { width: 90px; height: 90px; background: #c8530a; top: 12px; left: 40px; border-radius: 40% 60% 55% 45%; }
    .blob-2 { width: 70px; height: 70px; background: #f0b97a; top: 8px; left: 160px; border-radius: 50%; }
    .blob-3 { width: 80px; height: 80px; background: #6b9e6e; top: 14px; right: 160px; border-radius: 45% 55% 60% 40%; }
    .blob-4 { width: 65px; height: 65px; background: #e8d5a0; top: 20px; right: 60px; border-radius: 50%; }
    .blob-5 { width: 55px; height: 55px; background: #c8530a; bottom: 40px; left: 55px; border-radius: 60% 40% 50% 50%; opacity: 0.5; }
    .blob-6 { width: 48px; height: 48px; background: #8b6914; bottom: 50px; right: 80px; border-radius: 50%; opacity: 0.4; }

    /* Floating diagonal tag pills */
    .float-tag {
      position: absolute;
      background: #1a1008; color: #faf7f2;
      padding: 5px 12px; border-radius: 999px;
      font-size: 10px; font-weight: 700;
      letter-spacing: 0.02em; white-space: nowrap;
    }
    .tag-1 { top: 28px; left: 20px; transform: rotate(-8deg); background: #c8530a; }
    .tag-2 { bottom: 52px; left: 130px; transform: rotate(5deg); }
    .tag-3 { top: 36px; right: 20px; transform: rotate(6deg); background: #1a6b40; }

    /* Hero centre block */
    .site-hero-center { position: relative; z-index: 2; text-align: center; max-width: 580px; }
    .site-hero-eyebrow {
      display: inline-flex; align-items: center; gap: 7px;
      background: rgba(200,83,10,0.1); border: 1px solid rgba(200,83,10,0.2);
      border-radius: 999px; padding: 4px 12px;
      font-size: 10px; font-weight: 700; color: #c8530a;
      letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 14px;
    }
    .eyebrow-dot { width: 5px; height: 5px; background: #c8530a; border-radius: 50%; }
    .site-hero-h1 {
      font-size: clamp(26px, 3vw, 40px); font-weight: 900;
      letter-spacing: -0.045em; line-height: 1;
      color: #1a1008; margin: 0 0 12px;
    }
    .site-hero-h1 em { font-style: normal; color: #c8530a; }
    .site-hero-sub { font-size: 12px; color: rgba(0,0,0,0.5); line-height: 1.6; margin: 0 0 20px; }
    .site-hero-btns { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; }
    .site-hero-btn-primary { padding: 10px 20px; background: #1a1008; color: #faf7f2; border-radius: 999px; font-size: 12px; font-weight: 700; }
    .site-hero-btn-secondary { padding: 10px 20px; background: transparent; color: #1a1008; border-radius: 999px; font-size: 12px; font-weight: 600; border: 1.5px solid rgba(0,0,0,0.15); }

    /* Review badge bottom-right of hero */
    .hero-badge {
      position: absolute; bottom: 20px; right: 24px; z-index: 2;
      background: #1a1008; border-radius: 14px; padding: 10px 14px; text-align: center;
    }
    .hero-badge-num { font-size: 18px; font-weight: 900; color: #faf7f2; letter-spacing: -0.04em; }
    .hero-badge-stars { font-size: 9px; color: #f0b97a; letter-spacing: 1px; }
    .hero-badge-label { font-size: 9px; color: rgba(255,255,255,0.45); font-weight: 600; margin-top: 1px; }

    /* STATS STRIP */
    .site-stats-strip {
      background: #1a1008;
      padding: 12px 32px;
      display: flex; align-items: center; gap: 0;
    }
    .stat-item { display: flex; align-items: center; gap: 8px; flex: 1; justify-content: center; }
    .stat-num { font-size: 18px; font-weight: 900; color: #faf7f2; letter-spacing: -0.04em; }
    .stat-label { font-size: 10px; color: rgba(255,255,255,0.4); font-weight: 600; line-height: 1.3; }
    .stat-sep { width: 1px; height: 24px; background: rgba(255,255,255,0.1); }

    /* MENU SECTION */
    .site-menu-section { background: #faf7f2; padding: 32px 32px 28px; }
    .site-menu-header {
      display: flex; align-items: flex-end; justify-content: space-between;
      margin-bottom: 20px; gap: 16px;
    }
    .site-section-label { font-size: 10px; font-weight: 700; color: #c8530a; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 5px; }
    .site-section-h2 { font-size: clamp(18px, 2.2vw, 26px); font-weight: 900; letter-spacing: -0.04em; color: #1a1008; line-height: 1.1; margin: 0; }
    .site-menu-tag {
      background: #e8f5ec; border: 1px solid rgba(26,107,64,0.2);
      border-radius: 999px; padding: 5px 12px;
      font-size: 10px; font-weight: 700; color: #1a6b40; white-space: nowrap;
    }
    .site-menu-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    .site-menu-card {
      border-radius: 16px; padding: 18px;
      display: flex; flex-direction: column; gap: 5px;
    }
    .card-dark  { background: #1a1008; }
    .card-light { background: #fff; border: 1px solid rgba(0,0,0,0.07); }
    .card-accent { background: #fff5ec; border: 1px solid rgba(200,83,10,0.12); }
    .menu-card-emoji { font-size: 28px; margin-bottom: 8px; }
    .menu-card-name { font-size: 13px; font-weight: 800; letter-spacing: -0.02em; }
    .card-dark .menu-card-name { color: #faf7f2; }
    .card-light .menu-card-name, .card-accent .menu-card-name { color: #1a1008; }
    .menu-card-origin { font-size: 10px; font-weight: 600; color: #c8530a; text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px; }
    .menu-card-desc { font-size: 11px; line-height: 1.5; flex: 1; }
    .card-dark  .menu-card-desc { color: rgba(255,255,255,0.5); }
    .card-light .menu-card-desc, .card-accent .menu-card-desc { color: rgba(0,0,0,0.5); }
    .menu-card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 8px; }
    .menu-card-price { font-size: 16px; font-weight: 900; letter-spacing: -0.03em; }
    .card-dark  .menu-card-price { color: #f0b97a; }
    .card-light .menu-card-price, .card-accent .menu-card-price { color: #1a1008; }
    .menu-card-badge {
      font-size: 9px; font-weight: 700; padding: 3px 8px;
      border-radius: 999px; background: rgba(200,83,10,0.15); color: #c8530a;
    }
    .menu-card-badge.new { background: #1a6b40; color: #fff; }

    /* CTA SECTION */
    .site-cta-section { background: #c8530a; overflow: hidden; position: relative; }
    .cta-inner { padding: 32px; position: relative; z-index: 1; display: flex; flex-direction: column; }
    .cta-h2 { font-size: clamp(22px, 2.8vw, 34px); font-weight: 900; letter-spacing: -0.045em; color: #fff; margin: 6px 0 8px; line-height: 1; }
    .cta-sub { font-size: 12px; color: rgba(255,255,255,0.65); margin: 0 0 18px; line-height: 1.5; }
    .cta-btn { display: inline-flex; align-items: center; padding: 11px 22px; background: #1a1008; color: #faf7f2; border-radius: 999px; font-size: 13px; font-weight: 700; width: fit-content; }
    .cta-blob { position: absolute; border-radius: 50%; pointer-events: none; }
    .cta-blob-1 { width: 120px; height: 120px; background: rgba(255,255,255,0.1); top: -30px; right: 60px; }
    .cta-blob-2 { width: 80px; height: 80px; background: rgba(255,255,255,0.08); bottom: -20px; right: 20px; }
    .cta-pill {
      position: absolute; top: 20px; right: 24px;
      background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25);
      border-radius: 999px; padding: 5px 12px;
      font-size: 10px; font-weight: 700; color: rgba(255,255,255,0.9);
    }

    /* ══ TOASTS — inside site-viewport, bottom-left ══ */
    .site-toasts {
      position: absolute; bottom: 14px; left: 14px;
      display: flex; flex-direction: column; gap: 8px;
      z-index: 50; pointer-events: none;
    }
    .site-toast {
      display: flex; align-items: center; gap: 10px;
      background: #fff;
      border-radius: 12px; padding: 10px 13px;
      box-shadow: 0 6px 24px rgba(0,0,0,0.14), 0 1px 4px rgba(0,0,0,0.06);
      border: 1px solid rgba(0,0,0,0.07);
      opacity: 0; transform: translateX(-16px);
      min-width: 210px; max-width: 240px;
    }
    .site-toast-icon {
      width: 30px; height: 30px; border-radius: 50%;
      background: #fff5ef; display: flex; align-items: center; justify-content: center;
      font-size: 14px; flex-shrink: 0;
    }
    .site-toast-body { flex: 1; }
    .site-toast-name { font-size: 11px; font-weight: 700; color: #1a1008; margin-bottom: 1px; }
    .site-toast-detail { font-size: 10px; color: rgba(0,0,0,0.45); }
    .site-toast-time { font-size: 10px; color: rgba(0,0,0,0.28); font-weight: 600; flex-shrink: 0; }

    /* ══ CHAT — inside site-viewport, bottom-right ══ */
    .site-chat {
      position: absolute; bottom: 14px; right: 14px;
      width: 220px; z-index: 50; pointer-events: none;
      opacity: 0; border-radius: 12px;
      box-shadow: 0 6px 24px rgba(0,0,0,0.14), 0 1px 4px rgba(0,0,0,0.06);
      overflow: hidden;
    }
    .site-chat-header {
      background: #1a1008; padding: 10px 13px;
      display: flex; align-items: center; gap: 8px;
    }
    .site-chat-live-dot {
      width: 7px; height: 7px; background: #1aa463; border-radius: 50%;
      flex-shrink: 0; animation: pulse-dot 2s infinite;
    }
    .site-chat-title { font-size: 11px; font-weight: 700; color: #faf7f2; }
    .site-chat-sub   { font-size: 9px; color: rgba(255,255,255,0.4); margin-top: 1px; }
    .site-chat-body {
      background: #fff; padding: 10px 10px 8px;
      display: flex; flex-direction: column; gap: 7px;
      border: 1px solid rgba(0,0,0,0.07); border-top: none;
    }
    .site-chat-msg { display: flex; align-items: flex-start; gap: 6px; opacity: 0; transform: translateY(6px); }
    .site-chat-av {
      width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px; font-weight: 700; color: #fff;
    }
    .site-chat-bubble {
      background: #f4f1ea; border-radius: 2px 8px 8px 8px;
      padding: 6px 9px; font-size: 10px; color: #1a1008; line-height: 1.4;
      max-width: 160px;
    }
    .site-chat-bubble strong { font-weight: 700; }
    .site-chat-typing {
      display: flex; align-items: center; gap: 3px;
      padding: 7px 10px; background: #f4f1ea;
      border-radius: 2px 8px 8px 8px; width: fit-content;
