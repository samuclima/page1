<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<script>
  gsap.registerPlugin(ScrollTrigger);

  /* ─────────────────────────────────────────
     Char counter helpers (wizard phase)
  ───────────────────────────────────────── */
  const COFFEE_TEXTS = {
    desc:   'Specialty coffee shop in downtown Austin. We serve single-origin pour-overs, espresso drinks and house-made pastries daily, catering to remote workers and coffee enthusiasts.',
    uvp:    'Farm-direct beans from 3 family farms in Brazil & Ethiopia. Every cup brewed to order — no batch brewing, ever. Free pour-over class every Saturday morning.',
    visual: 'Warm earthy tones, rustic-modern aesthetic, kraft paper textures, hand-drawn typography accents.',
    comp:   "Starbucks, Dunkin', Peet's Coffee, local indie cafés",
  };
  const MINS = { desc: 80, uvp: 70, visual: 70, comp: 3 };

  function countCompetitors(str) {
    return str.split(',').map(function(s){ return s.trim(); }).filter(Boolean).length;
  }

  function updateCounter(key, p) {
    var text    = COFFEE_TEXTS[key];
    var partial = text.slice(0, Math.floor(text.length * p));
    var hint    = document.getElementById('hint-' + key);
    var num     = document.getElementById('num-'  + key);
    if (!hint || !num) return;
    if (key === 'comp') {
      var count = countCompetitors(partial);
      var ok    = count >= MINS.comp;
      hint.textContent = ok ? '✓ Looks good' : 'Add ' + (MINS.comp - count) + ' more competitor' + (MINS.comp - count > 1 ? 's' : '');
      hint.className   = 'onb-counter-hint' + (ok ? ' ok' : '');
      num.textContent  = count + ' / ' + MINS.comp;
      num.className    = 'onb-counter-num' + (ok ? ' ok' : '');
    } else {
      var len = partial.trim().length;
      var ok  = len >= MINS[key];
      hint.textContent = ok ? '✓ Looks good' : (MINS[key] - len) + ' more characters needed';
      hint.className   = 'onb-counter-hint' + (ok ? ' ok' : '');
      num.textContent  = len + ' / ' + MINS[key];
      num.className    = 'onb-counter-num' + (ok ? ' ok' : '');
    }
  }

  /* ─────────────────────────────────────────
     Tracker helpers (defined BEFORE the chain)
  ───────────────────────────────────────── */
  var CHECK_SVG = '<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6.5l2.5 2.5 5.5-5.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';

  function trackerActivate(num) {
    var el = document.getElementById('tst-' + num);
    if (!el) return;
    el.className = 'tracker-step step-active';
    var ind = el.querySelector('.tracker-step-indicator');
    ind.className = 'tracker-step-indicator ind-active';
    ind.innerHTML = '<div class="ind-active-dot"></div>';
    var badge = el.querySelector('.tracker-step-badge');
    badge.className = 'tracker-step-badge badge-active';
    badge.textContent = 'in progress';
    // Update pill and header
    var pill = document.querySelector('.tracker-status-pill');
    if (pill) pill.className = 'tracker-status-pill pill-active';
    var dot = document.getElementById('tracker-pill-dot');
    if (dot) dot.className = 'tracker-pill-dot dot-active';
    var pillLabel = document.getElementById('tracker-pill-label');
    if (pillLabel) pillLabel.textContent = 'In Progress · Step ' + num + ' of 8';
  }

  function trackerAdvance(doneNum, nextNum, pct) {
    var done = document.getElementById('tst-' + doneNum);
    if (!done) return;
    done.className = 'tracker-step step-done';
    var doneInd = done.querySelector('.tracker-step-indicator');
    doneInd.className = 'tracker-step-indicator ind-done';
    doneInd.innerHTML = CHECK_SVG;
    var doneBadge = done.querySelector('.tracker-step-badge');
    doneBadge.className = 'tracker-step-badge badge-done';
    doneBadge.textContent = 'completed';

    if (nextNum) {
      var next = document.getElementById('tst-' + nextNum);
      if (next) {
        next.className = 'tracker-step step-active';
        var nextInd = next.querySelector('.tracker-step-indicator');
        nextInd.className = 'tracker-step-indicator ind-active';
        nextInd.innerHTML = '<div class="ind-active-dot"></div>';
        var nextBadge = next.querySelector('.tracker-step-badge');
        nextBadge.className = 'tracker-step-badge badge-active';
        nextBadge.textContent = 'in progress';
      }
      var stepLabel = document.getElementById('tracker-h2-step');
      if (stepLabel) stepLabel.textContent = 'Step ' + nextNum + ' of 8';
      var pillLabel = document.getElementById('tracker-pill-label');
      if (pillLabel) pillLabel.textContent = 'In Progress · Step ' + nextNum + ' of 8';
    }

    var fill = document.getElementById('tracker-fill');
    if (fill) fill.style.width = pct + '%';
    var pctLabel = document.getElementById('tracker-pct-label');
    if (pctLabel) pctLabel.textContent = 'Progress · ' + pct + '%';
  }

  function trackerSetDelivered() {
    [5, 6, 7, 8].forEach(function(n) {
      var el = document.getElementById('tst-' + n);
      if (!el) return;
      el.className = 'tracker-step step-done';
      var ind = el.querySelector('.tracker-step-indicator');
      ind.className = 'tracker-step-indicator ind-done';
      ind.innerHTML = CHECK_SVG;
      var badge = el.querySelector('.tracker-step-badge');
      badge.className = 'tracker-step-badge badge-done';
      badge.textContent = 'completed';
    });

    var pill = document.querySelector('.tracker-status-pill');
    if (pill) pill.className = 'tracker-status-pill pill-done';
    var dot = document.getElementById('tracker-pill-dot');
    if (dot) { dot.className = 'tracker-pill-dot dot-done'; }
    var label = document.getElementById('tracker-pill-label');
    if (label) { label.className = 'tracker-pill-label label-done'; label.textContent = 'DELIVERED'; }

    var step = document.getElementById('tracker-h2-step');
    if (step) step.textContent = 'Complete';
    var fill = document.getElementById('tracker-fill');
    if (fill) fill.style.width = '100%';
    var pctLabel = document.getElementById('tracker-pct-label');
    if (pctLabel) pctLabel.textContent = 'Progress · 100%';
  }

  /* ─────────────────────────────────────────
     Main scroll timeline
  ───────────────────────────────────────── */
  var tl = gsap.timeline({
    scrollTrigger: {
      trigger: '.scroll-track',
      start: 'top top',
      end: 'bottom bottom',
      scrub: 0.5,
    }
  });

  /* PHASE 1 — hero out, card centres */
  tl.to('.hero-text', { opacity: 0, x: -50, duration: 1 }, 0)
    .to('.card-container', {
      right: 'auto', left: '50%', xPercent: -50, yPercent: -50,
      scale: 1.05, duration: 1.5, ease: 'power2.inOut'
    }, 0);

  /* PHASE 2 — fill sign-up form & click */
  tl.to('#fake-cursor', { opacity: 1, duration: 0.2 })
    .to('#fake-cursor', { x: '12vw', y: '-22vh', duration: 0.8, ease: 'power1.inOut' })
    .to('#input-name',  { '--ph-color': 'transparent', duration: 0.1 })
    .to('#fake-name',   { width: '100%', duration: 0.9 }, '<')
    .to('#fake-cursor', { x: '12vw', y: '-12vh', duration: 0.7, ease: 'power1.inOut' })
    .to('#input-email', { '--ph-color': 'transparent', duration: 0.1 })
    .to('#fake-email',  { width: '100%', duration: 0.9 }, '<')
    .to('#fake-cursor', { x: '12vw', y: '-2vh',  duration: 0.7, ease: 'power1.inOut' })
    .to('#input-pass',  { '--ph-color': 'transparent', duration: 0.1 })
    .to('#fake-pass',   { width: '100%', duration: 0.9 }, '<')
    .to('#fake-cursor', { x: '18vw', y: '8vh',  duration: 0.7, ease: 'power1.inOut' })
    .to('#fake-cursor', { scale: 0.8, duration: 0.15 })
    .to('#signup-btn',  { scale: 0.96, backgroundColor: '#e9581f', duration: 0.15 }, '<')
    .to('#fake-cursor', { scale: 1, duration: 0.15 })
    .to('#signup-btn',  { scale: 1, backgroundColor: '#ff6b2c', duration: 0.15 }, '<')
    .to('#fake-cursor', { opacity: 0, duration: 0.2 });

  /* PHASE 3 — flip card */
  tl.to('.card-inner', { rotationY: 180, duration: 2, ease: 'power2.inOut' }, '+=0.2');

  /* PHASE 4 — 3rd progress seg fills */
  tl.to({}, {
    duration: 0.5,
    onStart: function() { document.getElementById('prog-seg-3').classList.add('filled'); }
  }, '+=0.3');

  /* PHASE 5 — cursor fills wizard fields */
  tl.set('#fake-cursor', { x: 0, y: 0, scale: 1 })
    .to('#fake-cursor', { opacity: 1, duration: 0.2 }, '+=0.2')
    .to('#fake-cursor', { x: '-3vw', y: '-28vh', duration: 0.6, ease: 'power1.inOut' })
    .to('#onb-domain',  { '--onb-ph': 'transparent', duration: 0.1 })
    .to('#of-domain',   { width: '100%', duration: 0.7 }, '<')
    .to('#fake-cursor', { x: '-3vw', y: '-17vh', duration: 0.6, ease: 'power1.inOut' })
    .to('#onb-desc',    { '--onb-ph': 'transparent', duration: 0.1 })
    .to('#of-desc',     { width: '100%', height: '4.5em', duration: 1.2,
        onUpdate: function() { updateCounter('desc', this.progress()); }
      }, '<')
    .to('#fake-cursor', { x: '-3vw', y: '-4vh', duration: 0.6, ease: 'power1.inOut' })
    .to('#onb-uvp',     { '--onb-ph': 'transparent', duration: 0.1 })
    .to('#of-uvp',      { width: '100%', height: '3em', duration: 1.1,
        onUpdate: function() { updateCounter('uvp', this.progress()); }
      }, '<')
    .to('#fake-cursor', { x: '-3vw', y: '9vh',  duration: 0.5, ease: 'power1.inOut' })
    .to('#onb-visual',  { '--onb-ph': 'transparent', duration: 0.1 })
    .to('#of-visual',   { width: '100%', duration: 0.9,
        onUpdate: function() { updateCounter('visual', this.progress()); }
      }, '<')
    .to('#fake-cursor', { x: '-3vw', y: '20vh', duration: 0.5, ease: 'power1.inOut' })
    .to('#onb-comp',    { '--onb-ph': 'transparent', duration: 0.1 })
    .to('#of-comp',     { width: '100%', duration: 0.8,
        onUpdate: function() { updateCounter('comp', this.progress()); }
      }, '<')
    .to('#fake-cursor',    { x: '4vw', y: '28vh', duration: 0.6, ease: 'power1.inOut' })
    .to('#fake-cursor',    { scale: 0.8, duration: 0.15 })
    .to('#onb-submit-btn', { scale: 0.96, backgroundColor: '#e9581f', duration: 0.15 }, '<')
    .to('#fake-cursor',    { scale: 1, duration: 0.15 })
    .to('#onb-submit-btn', { scale: 1, backgroundColor: '#ff6b2c', duration: 0.15 }, '<')
    .to('#fake-cursor',    { opacity: 0, duration: 0.2 });

  /* PHASE 6 — card exits, browser slides up, tracker shows */
  tl.to('.card-container', {
      scale: 0.88, opacity: 0, y: -40,
      duration: 1.2, ease: 'power2.inOut'
    }, '+=0.3')
    .to('#browser-scene', {
      translateY: '0vh', opacity: 1,
      duration: 1.5, ease: 'power3.out',
      onStart: function() {
        document.getElementById('browser-scene').style.visibility = 'visible';
      }
    }, '-=0.6')
    .to('#build-overlay', { opacity: 1, duration: 0.4 }, '-=0.4')

    /* Tracker: activate step 5, then advance through each step */
    .to({}, { duration: 0.8,
      onStart: function() { trackerActivate(5); }
    }, '+=0.3')
    .to({}, { duration: 0.8,
      onStart: function() { trackerAdvance(5, 6, 63); }
    })
    .to({}, { duration: 0.8,
      onStart: function() { trackerAdvance(6, 7, 75); }
    })
    .to({}, { duration: 0.8,
      onStart: function() { trackerAdvance(7, 8, 88); }
    })
    .to({}, { duration: 0.8,
      onStart: function() { trackerSetDelivered(); }
    })

    /* Overlay fades out, website clips in */
    .to('#build-overlay', { opacity: 0, duration: 0.8 }, '+=0.5')
    .to('#site-content',  { clipPath: 'inset(0 0 0% 0)', duration: 2.5, ease: 'power2.inOut' }, '-=0.4')

    /* Chat + toasts appear inside the browser */
    .to('#chat-widget', { opacity: 1, duration: 0.5 }, '+=0.3')
    .to('#chat-1',      { opacity: 1, y: 0, duration: 0.35 })
    .to('#chat-2',      { opacity: 1, y: 0, duration: 0.35 }, '+=0.2')
    .to('#chat-3',      { opacity: 1, y: 0, duration: 0.35 }, '+=0.2')
    .to('#chat-typing', { opacity: 1, y: 0, duration: 0.25 }, '+=0.15')
    .to('#toast-1', { opacity: 1, x: 0, duration: 0.4, ease: 'back.out(1.5)' }, '-=0.8')
    .to('#toast-2', { opacity: 1, x: 0, duration: 0.4, ease: 'back.out(1.5)' }, '+=0.35')
    .to('#toast-3', { opacity: 1, x: 0, duration: 0.4, ease: 'back.out(1.5)' }, '+=0.35')
    .to({}, { duration: 1.5 })

  /* ─────────────────────────────────────────
     PHASE 7 — proof title fades in centred
     over the website (browser still visible behind)
  ───────────────────────────────────────── */
  /* Proof scene fades in — ensure browser stays behind vignette */
  .to('#proof-vignette',    { opacity: 1, duration: 0.8 }, '+=0.5')
  .to('#proof-hero-block',  { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out' }, '-=0.4')
  .to({}, { duration: 1.5 }) /* hold so reader can read */

  /* ─────────────────────────────────────────
     PHASE 8 — portfolio scene takes over
     Title slides up → cards stack in one by one
  ───────────────────────────────────────── */

  /* Portfolio scene slides up */
  .to('#portfolio-scene', { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
    onStart: function() { document.getElementById('portfolio-scene').style.pointerEvents = 'auto'; }
  }, '+=0.2')
  .to('#proof-scene',     { opacity: 0, duration: 0.4 }, '<')

  /* Header slides up */
  .to('#portfolio-header', { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, '-=0.1')
  .to({}, { duration: 0.4 })

  /* Cards slide up from bottom, one by one, each slightly offset so you see the stack */
  /* Card 4 — bottom of visual stack, slides in first, sits furthest back */
  .to('#psc-4', {
    translateY: '-8px', translateZ: '-60px', rotateX: '3deg',
    scale: 0.88, duration: 0.7, ease: 'power3.out'
  })
  /* Card 3 */
  .to('#psc-3', {
    translateY: '-4px', translateZ: '-30px', rotateX: '1.5deg',
    scale: 0.93, duration: 0.7, ease: 'power3.out'
  }, '+=0.25')
  /* Card 2 */
  .to('#psc-2', {
    translateY: '0px', translateZ: '-10px', rotateX: '0.5deg',
    scale: 0.97, duration: 0.7, ease: 'power3.out'
  }, '+=0.25')
  /* Card 1 — top card, full size, snaps into place */
  .to('#psc-1', {
    translateY: '0px', translateZ: '0px', rotateX: '0deg',
    scale: 1, duration: 0.8, ease: 'back.out(1.2)'
  }, '+=0.25')

  /* Hold on the final stacked scene */
  .to({}, { duration: 1.5 })

  /* ─────────────────────────────────────────
     PHASE 9 — Compare: 3 cards stack up
  ───────────────────────────────────────── */
  .to('#compare-scene',  { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, '+=0.3')
  .to('#portfolio-scene', { opacity: 0, duration: 0.4,
    onStart: function() { document.getElementById('portfolio-scene').style.pointerEvents = 'none'; }
  }, '<')
  .to('#browser-scene',   { opacity: 0, duration: 0.3,
    onComplete: function() {
      var el = document.getElementById('browser-scene');
      el.style.visibility = 'hidden';
    },
    onReverseComplete: function() {
      var el = document.getElementById('browser-scene');
      el.style.visibility = 'visible';
    }
  }, '<')

  /* Cards slide up side by side */
  .to('#csc-1', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '+=0.2')
  .to('#csc-2', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '+=0.15')
  .to('#csc-3', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '+=0.15')
  .to({}, { duration: 1.5 })

  /* ─────────────────────────────────────────
     PHASE 10 — How it works: 3 cards slide up
  ───────────────────────────────────────── */
  .to('#how-scene',     { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out' }, '+=0.3')
  .to('#compare-scene', { opacity: 0, duration: 0.4 }, '<')
  .to('#how-1', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '+=0.2')
  .to('#how-2', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '+=0.18')
  .to('#how-3', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, '+=0.18')
  .to({}, { duration: 1.5 })

  /* ─────────────────────────────────────────
     PHASE 11 — Pricing card slides up
  ───────────────────────────────────────── */
  .to('#pricing-scene', { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
    onStart: function() { document.getElementById('pricing-scene').style.pointerEvents = 'auto'; }
  }, '+=0.3')
  .to('#how-scene',     { opacity: 0, duration: 0.4,
    onStart: function() { document.getElementById('how-scene').style.pointerEvents = 'none'; }
  }, '<')
  .to('#price-main-card', { translateY: '0px', opacity: 1, duration: 1, ease: 'power3.out' }, '+=0.2')
  .to({}, { duration: 1.5 })

  /* Hold on pricing */
  .to({}, { duration: 1.5 });


</script>

</body>
</html>
