    .badge-done    { color: rgba(40,200,64,0.7); }
    .badge-active  { color: rgba(255,255,255,0.8); }
    .badge-pending { color: rgba(255,255,255,0.3); }
    .badge-locked  { color: rgba(255,255,255,0.2); }
    .badge-delivered { color: #28C840; }

    /* Footer */
    .tracker-footer {
      padding: 10px 20px 14px;
      border-top: 1px solid rgba(255,255,255,0.05);
      margin-top: 4px;
    }
    .tracker-footer-left { display: flex; align-items: center; gap: 16px; }
    .tracker-progress-label {
      font-size: 10px; font-weight: 700; color: rgba(255,255,255,0.5);
      letter-spacing: 0.08em; text-transform: uppercase;
      font-family: ui-monospace, monospace; white-space: nowrap;
    }
    .tracker-progress-track {
      flex: 1; max-width: 280px; height: 6px;
      background: rgba(0,0,0,0.6); border-radius: 999px;
      overflow: hidden; border: 1px solid rgba(255,255,255,0.05);
